# Frontend environment configuration
# Copy this file to `.env` (or `.env.local`) and edit as needed.
# Both files are gitignored — do not commit real values.

# Base URL of the TrueSight backend API.
# - Local development: http://localhost:8000
# - Vercel deployment: set this in the Vercel project's Environment Variables
#   to the public URL of your deployed backend (e.g. Render, Fly, Railway).
VITE_API_URL=http://localhost:8000
